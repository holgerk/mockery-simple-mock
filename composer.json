{
    "name": "holgerk/mockery-simple-mock",
    "description": "Simple mock helper for Mockery",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "mockery/mockery": "^1.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Holgerk\\MockerySimpleMock\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Holgerk\\MockerySimpleMock\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
